// ── IMPORT ───────────────────────────────────────────────────────
function handleImportFile(file){
  if(!file) return;
  const mode = document.querySelector('input[name="import-mode"]:checked').value;
  const reader = new FileReader();
  reader.onload = e => {
    const text = e.target.result;
    if(file.name.endsWith('.json')){
      importJSON(text, mode);
    } else if(file.name.endsWith('.txt')){
      importTXT(text, mode);
    } else {
      showImportStatus('err','Unbekanntes Dateiformat. Bitte JSON oder TXT importieren.');
    }
  };
  reader.readAsText(file, 'utf-8');
}

function importJSON(text, mode){
  try{
    const data = JSON.parse(text);
    if(!data.cards||!Array.isArray(data.cards)) throw new Error('Kein gültiges Backup-Format.');
    const lib = mode==='replace' ? [] : getLibrary();
    const existing = new Set(lib.map(c=>c.id));
    let added=0, skipped=0;
    data.cards.forEach(c=>{
      if(existing.has(c.id)){ skipped++; }
      else { lib.push(c); added++; }
    });
    setLibrary(lib);
    renderLibrary();
    showImportStatus('ok',`✓ ${added} Karte(n) importiert${skipped?', '+skipped+' übersprungen (bereits vorhanden)':''}.`);
  }catch(err){
    showImportStatus('err','Fehler: '+err.message);
  }
}

function importTXT(text, mode){
  const sections = text.split(/\n?=== /);
  let added=0;
  const lib = mode==='replace' ? [] : getLibrary();
  sections.forEach(sec=>{
    sec=sec.trim(); if(!sec) return;
    const nl = sec.indexOf('\n');
    if(nl<0) return;
    let title = sec.slice(0,nl).replace(/\s*===\s*$/,'').trim();
    const body  = sec.slice(nl+1);
    if(!title) return;
    const lns = body.split('\n').filter(l=>l.trim());
    if(!lns.length) return;
    const cardLines = lns.map(l=>{
      const spaces = l.match(/^[\s]*/)[0].replace(/\t/g,'  ').length;
      const indent = Math.min(4, Math.floor(spaces/2));
      const txt = l.trim().replace(/^[IVXivxABCDEFGHabc]{1,4}[.)]\s*/,'').replace(/^\d+[.)]\s*/,'');
      return {indent, text: txt};
    });
    lib.push({id:Date.now().toString()+Math.random().toString(36).slice(2,6), title, lines:cardLines, savedAt:Date.now()});
    added++;
  });
  setLibrary(lib);
  renderLibrary();
  showImportStatus('ok',`✓ ${added} Karte(n) aus TXT importiert.`);
}

function showImportStatus(type, msg){
  const el = document.getElementById('import-status');
  el.className='import-status '+type;
  el.textContent=msg;
}

// ── HELPERS ──────────────────────────────────────────────────────
function download(data, filename, type){
  const blob = data instanceof Blob ? data : new Blob([data],{type});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download=filename;
  document.body.appendChild(a);
  a.click();
  setTimeout(()=>{ URL.revokeObjectURL(a.href); document.body.removeChild(a); },1000);
}

function loadScript(url){
  return new Promise((resolve,reject)=>{
    if(document.querySelector(`script[src="${url}"]`)){ resolve(); return; }
    const s=document.createElement('script');
    s.src=url; s.onload=resolve; s.onerror=()=>reject(new Error(`Konnte ${url} nicht laden`));
    document.head.appendChild(s);
  });
}

function dateStamp(){
  const d=new Date();
  return `${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}`;
}

let toastTimer;
function toast(msg, type=''){
  const el=document.getElementById('toast');
  el.textContent=msg;
  el.className='toast '+(type||'');
  el.classList.add('vis');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.classList.remove('vis'),3000);
}

// ── DRAG DROP IMPORT ─────────────────────────────────────────────
const zone = document.getElementById('import-zone');
zone.addEventListener('dragover', e=>{e.preventDefault();zone.classList.add('drag');});
zone.addEventListener('dragleave', ()=>zone.classList.remove('drag'));
zone.addEventListener('drop', e=>{
  e.preventDefault(); zone.classList.remove('drag');
  const file=e.dataTransfer.files[0];
  if(file) handleImportFile(file);
});

// ── BEFORE UNLOAD ────────────────────────────────────────────────
window.addEventListener('beforeunload', e=>{
  if(getLibrary().length>0 && !sessionStorage.getItem('exported')){
    e.preventDefault();
    e.returnValue='';
  }
});

